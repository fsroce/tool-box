# 默认使用 Tushare 文档中 realtime_quote 对应的爬虫行情源（新浪）。
# 该实时行情源不经过 Tushare Pro HTTP，也不需要 Token。
TUSHARE_QUOTE_SOURCE=sina
TUSHARE_REALTIME_ENDPOINT=https://hq.sinajs.cn/list=
PORT=4173
STOCK_PORTFOLIO_DB=./data/portfolio.sqlite

# 如果你明确要走 Tushare Pro HTTP，请改成 TUSHARE_QUOTE_SOURCE=pro，
# 并配置一个真实存在的 Pro HTTP API 名称和 Token（不要使用 realtime_quote）。
# TUSHARE_QUOTE_SOURCE=pro
# TUSHARE_TOKEN=your_tushare_token_here
# TUSHARE_API_NAME=your_pro_http_api_name
# TUSHARE_ENDPOINT=http://api.tushare.pro

# 可选：指定用于访问 SQLite 的 Python 可执行文件（使用 Python 标准库 sqlite3，无需 npm 原生依赖）。
# PYTHON=python3
