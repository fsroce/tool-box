# 复制为 .env.prod 后按需填写你的本机配置。
# .env.prod 已被 .gitignore 忽略，不要把管理密码或行情 Token 提交到 Git。

# 默认行情和证券名称解析走新浪公开接口，不需要 Tushare Token。
# 如果要使用 Tushare 实时价格，把 PORTFOLIO_QUOTE_SOURCE 改为 tushare，并填写 TUSHARE_TOKEN。
PORTFOLIO_QUOTE_SOURCE=sina
SINA_REALTIME_ENDPOINT=https://hq.sinajs.cn/list=
SINA_SUGGEST_ENDPOINT=https://suggest3.sinajs.cn/suggest/type=11,12&key=
PORT=4173
HOST=127.0.0.1
PORTFOLIO_CORS_ORIGINS=https://bytedarice.com,https://www.bytedarice.com

# 管理台鉴权。复制后请把 change-me 改成强密码。
PORTFOLIO_AUTH_USERNAME=admin
PORTFOLIO_AUTH_PASSWORD=change-me
PORTFOLIO_AUTH_SESSION_TTL_HOURS=12

# 可选：如果价格更新要走 Tushare，Token 只放服务端环境变量，前端不可见。
# PORTFOLIO_QUOTE_SOURCE=tushare
# TUSHARE_TOKEN=your_tushare_token_here
# TUSHARE_API_NAME=rt_k
# TUSHARE_ENDPOINT=http://api.tushare.pro

# 可选：只有明确想使用 Tushare realtime_quote 爬虫版时才开启。
# TUSHARE_API_NAME=realtime_quote
# TUSHARE_REALTIME_MODE=crawler
# TUSHARE_REALTIME_SRC=sina
